rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT MODE: Allow read/write for everything to unblock the project
    // WARNING: In production, you should restrict this to authenticated admins.
    match /{document=**} {
      allow read, write: if true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn();
    }

    match /config/{configId} {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }

    match /skills/{skillId} {
      allow read, write: if true;
    }
  }
}
